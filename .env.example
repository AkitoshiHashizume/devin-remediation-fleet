# --- Devin API (v3 service-user token, prefix cog_) ---
DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxx
DEVIN_ORG_ID=org_xxxxxxxx
DEVIN_API_BASE=https://api.devin.ai/v3

# --- GitHub ---
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx
GITHUB_REPO=your-org/superset
GITHUB_WEBHOOK_SECRET=change-me

# --- Modes ---
# MOCK_MODE=1 runs the full flow with zero credentials (no Devin/GitHub calls).
MOCK_MODE=0
# KILL_SWITCH=1 stops launching new Devin sessions; event intake and polling continue.
KILL_SWITCH=0

# --- Guardrails ---
MAX_CONCURRENT_SESSIONS=3
# per-session compute cap: Devin halts the session at this limit (runaway protection)
MAX_ACU_PER_SESSION=8
DAILY_SESSION_BUDGET=15
POLL_INTERVAL_SECONDS=20
DISPATCH_INTERVAL_SECONDS=10
STALE_AFTER_MINUTES=45

# --- Webhook forwarding (only needed for the smee compose profile) ---
SMEE_URL=

# --- Optional overrides ---
# DB_PATH=data/fleet.sqlite3
# SNAPSHOT_ID=
# PLAYBOOK_ID=
